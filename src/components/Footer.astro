---
const year = new Date().getFullYear();
---

<footer class="bg-[var(--color-forest-deep)] text-[var(--color-bone)]/70 py-12">
  <div class="max-w-6xl mx-auto px-6 lg:px-10 flex flex-col md:flex-row items-center justify-between gap-6">
    <div class="flex items-center gap-3">
      <img src="/logo-white.png" alt="" class="w-9 h-9 object-contain" />
      <span class="font-serif text-2xl text-[var(--color-bone)] tracking-[0.25em] uppercase">
        Samma
      </span>
    </div>
    <p class="text-xs tracking-wide text-center">
      Av. Manquehue Sur 520, Las Condes &nbsp;·&nbsp; +56 9 8739 0802
    </p>
    <p class="text-xs tracking-wide">© {year} Samma</p>
  </div>
</footer>
