---
// Formulario gestionado por Netlify Forms.
// Netlify detecta el atributo `data-netlify="true"` durante el build.
---

<section id="contacto" class="py-24 md:py-36 bg-[var(--color-forest)] text-[var(--color-bone)]">
  <div class="max-w-5xl mx-auto px-6 lg:px-10 grid md:grid-cols-2 gap-16">
    <div class="reveal">
      <span class="label-eyebrow text-[var(--color-brass-soft)]">— Contacto</span>
      <h2 class="mt-6 text-4xl md:text-5xl text-[var(--color-bone)] leading-tight">
        Reserva tu sesión.
      </h2>
      <span class="divider-brass mt-8"></span>
      <p class="mt-8 text-[var(--color-bone)]/80 leading-relaxed">
        Cuéntanos qué necesitas y te respondemos en el día. Si prefieres una conversación
        directa, escríbenos por WhatsApp.
      </p>

      <a
        href="https://wa.me/56987390802?text=Hola%20Samma%2C%20me%20gustar%C3%ADa%20agendar%20una%20sesi%C3%B3n."
        target="_blank"
        rel="noopener"
        class="mt-10 inline-flex items-center gap-3 px-7 py-4 rounded-full bg-[var(--color-bone)] text-[var(--color-forest)] text-sm uppercase tracking-[0.15em] hover:bg-[var(--color-brass-soft)] transition-colors"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.6 6.32A7.85 7.85 0 0 0 12.05 4a7.94 7.94 0 0 0-6.88 11.9L4 20l4.2-1.1a7.93 7.93 0 0 0 3.85.98h.01a7.94 7.94 0 0 0 7.94-7.94 7.88 7.88 0 0 0-2.4-5.62Zm-5.55 12.21h-.01a6.6 6.6 0 0 1-3.36-.92l-.24-.14-2.49.65.66-2.43-.16-.25a6.6 6.6 0 0 1-1.01-3.5 6.6 6.6 0 0 1 11.27-4.67 6.55 6.55 0 0 1 1.93 4.67 6.6 6.6 0 0 1-6.59 6.59Zm3.62-4.94c-.2-.1-1.18-.58-1.36-.65-.18-.07-.31-.1-.45.1-.13.2-.51.65-.63.78-.12.13-.23.15-.43.05-.2-.1-.84-.31-1.6-.99-.59-.52-.99-1.17-1.1-1.37-.12-.2-.01-.31.09-.41.09-.09.2-.23.3-.35.1-.12.13-.2.2-.33.07-.13.03-.25-.02-.35-.05-.1-.45-1.08-.61-1.48-.16-.39-.33-.34-.45-.34l-.39-.01c-.13 0-.35.05-.53.25-.18.2-.7.68-.7 1.66 0 .98.71 1.92.81 2.05.1.13 1.4 2.13 3.39 2.99.47.2.84.32 1.13.41.48.15.91.13 1.25.08.38-.06 1.18-.48 1.34-.95.16-.47.16-.86.12-.95-.05-.08-.18-.13-.38-.23Z"/>
        </svg>
        Escribir por WhatsApp
      </a>
    </div>

    <form
      name="contact"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="reveal space-y-6"
    >
      <input type="hidden" name="form-name" value="contact" />
      <p class="hidden">
        <label>No llenar: <input name="bot-field" /></label>
      </p>

      <div>
        <label for="nombre" class="block text-xs uppercase tracking-[0.2em] text-[var(--color-brass-soft)] mb-2">
          Nombre
        </label>
        <input
          type="text"
          id="nombre"
          name="nombre"
          required
          class="w-full bg-transparent border-b border-[var(--color-bone)]/30 py-3 text-[var(--color-bone)] placeholder-[var(--color-bone)]/40 focus:outline-none focus:border-[var(--color-brass-soft)] transition-colors"
        />
      </div>

      <div>
        <label for="email" class="block text-xs uppercase tracking-[0.2em] text-[var(--color-brass-soft)] mb-2">
          Email
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full bg-transparent border-b border-[var(--color-bone)]/30 py-3 text-[var(--color-bone)] placeholder-[var(--color-bone)]/40 focus:outline-none focus:border-[var(--color-brass-soft)] transition-colors"
        />
      </div>

      <div>
        <label for="telefono" class="block text-xs uppercase tracking-[0.2em] text-[var(--color-brass-soft)] mb-2">
          Teléfono
        </label>
        <input
          type="tel"
          id="telefono"
          name="telefono"
          class="w-full bg-transparent border-b border-[var(--color-bone)]/30 py-3 text-[var(--color-bone)] placeholder-[var(--color-bone)]/40 focus:outline-none focus:border-[var(--color-brass-soft)] transition-colors"
        />
      </div>

      <div>
        <label for="mensaje" class="block text-xs uppercase tracking-[0.2em] text-[var(--color-brass-soft)] mb-2">
          Mensaje
        </label>
        <textarea
          id="mensaje"
          name="mensaje"
          rows="4"
          required
          class="w-full bg-transparent border-b border-[var(--color-bone)]/30 py-3 text-[var(--color-bone)] placeholder-[var(--color-bone)]/40 focus:outline-none focus:border-[var(--color-brass-soft)] transition-colors resize-none"
        ></textarea>
      </div>

      <button
        type="submit"
        class="mt-4 inline-flex items-center gap-3 px-7 py-4 rounded-full border border-[var(--color-bone)]/60 text-[var(--color-bone)] text-sm uppercase tracking-[0.15em] hover:bg-[var(--color-bone)] hover:text-[var(--color-forest)] transition-colors"
      >
        Enviar mensaje
      </button>
    </form>
  </div>
</section>
